# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/upi-secure-pay

# Authentication
SECRET_KEY=your-long-random-secret-key-here-minimum-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis
REDIS_URL=redis://localhost:6379

# ML Model Paths
LGBM_MODEL_PATH=./lgbm_fraud_model.pkl
LSTM_MODEL_PATH=./lstm_model.pth
PAYSIM_MODEL_PATH=./paysim_model.pkl
IEEE_MODEL_PATH=./ieee_model.pkl
LGBM_FEATURES_PATH=./lgbm_features.json

# App Settings
DEBUG_MODE=True
DEMO_MODE=True
DEMO_TRANSACTION_INTERVAL_SECONDS=5

# SMTP (Optional - not yet implemented)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
